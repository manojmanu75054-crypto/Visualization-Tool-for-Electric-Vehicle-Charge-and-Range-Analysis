    <dashboard name='Story 1' type='storyboard'>
      <style />
      <size sizing-mode='automatic' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='98120' id='1' param='vert' removable='false' type-v2='layout-flow' w='99058' x='471' y='940'>
            <zone h='4935' id='3' type-v2='title' w='99058' x='471' y='940' />
            <zone h='11868' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='99058' x='471' y='5875' />
            <zone h='81317' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='99058' x='471' y='17743'>
              <flipboard active-id='5' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='This dashboard presents an analysis of electric vehicle specifications including driving range, price, charging capability, and brand-wise performance. It helps compare EV models and identify high-performing vehicles based on multiple factors.' captured-sheet='Dashboard 1' id='2' />
                  <story-point caption='This analysis compares the average driving range offered by different electric vehicle brands. Brands with higher range are more suitable for long-distance travel.' captured-sheet='Dashboard 1' id='3' />
                  <story-point caption='The scatter plot shows the relationship between vehicle price and driving range. It highlights that higher-priced vehicles generally provide greater driving range.' captured-sheet='Dashboard 1' id='4' />
                  <story-point caption='This visualization shows the proportion of electric vehicles that support rapid charging. Most vehicles in the dataset include rapid charging capability' captured-sheet='Dashboard 1' id='5' />
                  <story-point caption='The dashboard demonstrates that range, charging speed, and price are key factors in evaluating electric vehicles. It provides insights that help users compare models and make informed decisions.&#9;' captured-sheet='Dashboard 1' id='6' />
                </story-points>
              </flipboard>
            </zone>
          </zone>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='margin' value='8' />
          </zone-style>
        </zone>
      </zones>
      <simple-id uuid='{362AE394-209D-4A7A-8FA1-8511F193B81F}' />
    </dashboard>
